# Database (Neon / Vercel Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# NextAuth
NEXTAUTH_URL=http://localhost:3000  # Production: https://portal.nexli.net
NEXTAUTH_SECRET=  # Generate with: openssl rand -base64 32

# Admin seeding
ADMIN_INITIAL_PASSWORD=  # Strong password for mail@nexli.net

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Vercel Analytics API
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=team_Gmt8LmYuSCUbxbFGNfUAfyyA

# GoHighLevel
GHL_API_KEY=
GHL_LOCATION_ID=

# Supabase (Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Portal URL (for generating secure upload links)
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000  # Production: https://portal.nexli.net

# Resend (Email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Nexli Portal <documents@nexli.net>

# Anthropic (AI Insights)
ANTHROPIC_API_KEY=

# Meta Pixel & Conversions API
NEXT_PUBLIC_META_PIXEL_ID=910151701422761
META_CAPI_ACCESS_TOKEN=          # Generate in Events Manager > Settings > Conversions API
META_API_VERSION=v21.0
META_TEST_EVENT_CODE=            # Set for test mode (e.g. TEST12345), remove for production

# CRM Webhook Security (for GHL lifecycle webhooks)
CRM_WEBHOOK_SECRET=              # Shared secret — generate with: openssl rand -hex 32

# GHL Webhooks (moved from hardcoded URLs)
