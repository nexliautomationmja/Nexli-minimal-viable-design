# Database (Neon / Vercel Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# NextAuth
NEXTAUTH_URL=http://localhost:3000  # Production: https://portal.nexli.net
NEXTAUTH_SECRET=  # Generate with: openssl rand -base64 32

# Admin seeding
ADMIN_INITIAL_PASSWORD=  # Strong password for mail@nexli.net

# Helcim (Payment Processing)
HELCIM_API_TOKEN=
HELCIM_WEBHOOK_SECRET=       # base64-encoded verifier token from Helcim dashboard
HELCIM_HOSTED_URL=           # e.g. https://nexli.myhelcim.com

# Vercel Analytics API
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=team_Gmt8LmYuSCUbxbFGNfUAfyyA

# GoHighLevel
GHL_API_KEY=
GHL_LOCATION_ID=

# Supabase (Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Portal URL (for generating secure upload links)
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000  # Production: https://portal.nexli.net

# Resend (Email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Nexli Portal <documents@nexli.net>

# Anthropic (AI Insights)
ANTHROPIC_API_KEY=
